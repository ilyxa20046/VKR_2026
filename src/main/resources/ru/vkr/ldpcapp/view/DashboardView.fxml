<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="screen-scroll-pane dashboard-scroll-pane"
            xmlns:fx="http://javafx.com/fxml">
    <content>
        <VBox spacing="16.0" styleClass="screen-root dashboard-screen-content">
            <children>

                <VBox spacing="10.0" styleClass="screen-hero hero-gradient-card hero-gradient-indigo">
                    <children>
                        <Label styleClass="screen-title" text="Исследовательская среда" />
                        <Label styleClass="screen-subtitle"
                               wrapText="true"
                               text="Исследовательская среда: моделирование помехоустойчивого кодирования в зашумлённом канале мобильной сети 5G с расширенным сравнением LDPC (5G NR) и Turbo (4G LTE)." />
                        <Label styleClass="helper-text"
                               wrapText="true"
                               text="В одном приложении доступны одиночные эксперименты, A/B-сравнение, пакетный анализ сценариев, BER/BLER-графики, MCS-подобные профили и экспорт материалов." />
                    </children>
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                    </padding>
                </VBox>

                <GridPane hgap="12.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50.0" />
                        <ColumnConstraints percentWidth="50.0" />
                    </columnConstraints>

                    <children>
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="8.0" styleClass="panel-card compact-card pastel-card-blue">
                            <children>
                                <Label styleClass="panel-title" text="Что моделируется" />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Передача цифровых данных с кодированием LDPC/Turbo через каналы AWGN и Рэлеевский." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Влияние модуляции, OFDM-представления, эквализации и пространственного режима на BER/BLER." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Компромисс между надёжностью и производительностью по метрикам полезной скорости и спектральной эффективности." />
                            </children>
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                            </padding>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="8.0" styleClass="panel-card compact-card pastel-card-mint">
                            <children>
                                <Label styleClass="panel-title" text="Ключевые возможности" />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Одиночный эксперимент: настройка сценария и расчёт BER/BLER по сетке SNR." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Сравнение A/B: автоматический выбор победителя по BER/BLER, требуемому SNR и инженерным KPI." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Пакетный анализ: массовый расчёт комбинаций модуляция/канал/профиль/скорость кода." />
                            </children>
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                            </padding>
                        </VBox>

                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="8.0" styleClass="panel-card compact-card pastel-card-yellow">
                            <children>
                                <Label styleClass="panel-title" text="Метрики и графики" />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• BER(SNR), BLER(SNR), полезная скорость(SNR), спектральная эффективность(SNR)." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Теоретические кривые: BER BPSK (Q-функция) и граница Шеннона для выбранной скорости кода." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Доверительные интервалы BER/BLER, анализ сходимости и HARQ-метрики." />
                            </children>
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                            </padding>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="8.0" styleClass="panel-card compact-card pastel-card-violet">
                            <children>
                                <Label styleClass="panel-title" text="Экспорт результатов" />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Таблицы результатов и сводки по сценариям." />
                                <Label styleClass="dashboard-bullet" wrapText="true" maxWidth="Infinity"
                                       text="• Экспорт графиков, CSV, текстовых отчётов." />
                            </children>
                            <padding>
                                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                            </padding>
                        </VBox>
                    </children>
                </GridPane>

                <VBox spacing="10.0" styleClass="panel-card compact-card pastel-card-slate">
                    <children>
                        <Label styleClass="panel-title" text="Рекомендуемый сценарий работы" />
                        <GridPane hgap="12.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50.0" />
                                <ColumnConstraints percentWidth="50.0" />
                            </columnConstraints>
                            <children>
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="4.0" styleClass="compact-card">
                                    <children>
                                        <Label styleClass="info-title" text="1. Настройка эксперимента" />
                                        <Label styleClass="helper-text" wrapText="true"
                                               text="Откройте «Моделирование», задайте профиль кодирования, канал, модуляцию, диапазон SNR и число итераций декодера." />
                                    </children>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="4.0" styleClass="compact-card">
                                    <children>
                                        <Label styleClass="info-title" text="2. Расчёт и анализ" />
                                        <Label styleClass="helper-text" wrapText="true"
                                               text="Выполните расчёт, проверьте BER/BLER-кривые, требуемый SNR и соответствие теоретическим референсам." />
                                    </children>
                                </VBox>

                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="4.0" styleClass="compact-card">
                                    <children>
                                        <Label styleClass="info-title" text="3. Сравнение сценариев" />
                                        <Label styleClass="helper-text" wrapText="true"
                                               text="На вкладке «Сравнение» выполните A/B-анализ LDPC и Turbo, затем подтвердите выводы пакетным запуском." />
                                    </children>
                                </VBox>

                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="4.0" styleClass="compact-card">
                                    <children>
                                        <Label styleClass="info-title" text="4. Экспорт результатов" />
                                        <Label styleClass="helper-text" wrapText="true"
                                               text="Сохраните графики, таблицы и отчётные материалы в форматах." />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                    <padding>
                        <Insets top="12.0" right="12.0" bottom="12.0" left="12.0" />
                    </padding>
                </VBox>

            </children>
            <padding>
                <Insets top="4.0" right="4.0" bottom="10.0" left="4.0" />
            </padding>
        </VBox>
    </content>
</ScrollPane>